OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# Vector store: omit VECTOR_STORE to auto-select Pinecone when PINECONE_API_KEY + PINECONE_INDEX are set, else FAISS.
# VECTOR_STORE=faiss
# VECTOR_STORE=pinecone
PINECONE_API_KEY=

# --- Pinecone indexes (create these exact names in the Pinecone console, serverless, metric=cosine) ---
# Index name is only a label: the dimension you choose when creating the index must match the embedder
# (e.g. a name like bookchat-google-gemini-3072 must still be created with dimension 3072 in Pinecone).
#
# | Env value                      | Index name to create    | Dimension | Matches embedder / notes |
# |--------------------------------|---------------------------|-----------|---------------------------|
# | PINECONE_INDEX (fallback)      | bookchat-ollama-nomic-768 | 768       | OLLAMA_EMBED_MODEL=nomic-embed-text |
# | PINECONE_INDEX_OLLAMA          | bookchat-ollama-nomic-768 | 768       | same row as above         |
# | PINECONE_INDEX_GOOGLE          | bookchat-google-gemini-3072 | 3072   | GEMINI_EMBED_MODEL=gemini-embedding-001 (API default vector size) |
#
# Routing: google -> PINECONE_INDEX_GOOGLE (else PINECONE_INDEX); ollama -> PINECONE_INDEX_OLLAMA (else PINECONE_INDEX).
# If Gemini upserts fail with a dimension error, check the vector length from the API and recreate the Google index to match.
PINECONE_INDEX=bookchat-ollama-nomic-768
PINECONE_INDEX_OLLAMA=bookchat-ollama-nomic-768
PINECONE_INDEX_GOOGLE=bookchat-google-gemini-3072

# Defaults for POST /admin/pinecone/index (programmatic serverless index creation).
# PINECONE_SERVERLESS_CLOUD=aws
# PINECONE_SERVERLESS_REGION=us-east-1
#
# Example (requires ADMIN_API_TOKEN if set on the server):
# curl -sS -X POST "http://127.0.0.1:8001/admin/pinecone/index" \
#   -H "Content-Type: application/json" -H "X-Admin-Token: YOUR_TOKEN" \
#   -d '{"name":"bookchat-google-gemini-3072","preset":"google"}'

CHUNK_SIZE=900
CHUNK_OVERLAP=150
